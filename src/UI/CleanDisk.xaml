<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanDisk - Effacement securise de disques - LOGICIA INFORMATIQUE"
        Height="750"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- En-tete avec titre et indicateur d'etape -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TxtStepTitle"
                              Text="Dashboard - Vue d'ensemble"
                              Foreground="#2c3e50"
                              FontSize="22"
                              FontWeight="Bold"/>
                    <TextBlock x:Name="TxtStepDescription"
                              Text="Statistiques et activite recente"
                              Foreground="#7f8c8d"
                              FontSize="13"
                              Margin="0,5,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="LOGICIA" FontSize="18" FontWeight="Bold" Foreground="#667eea" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Conteneur des etapes -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Margin="0,10,0,10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.15"/>
            </Border.Effect>
            <Grid>

            <!-- ============================================ -->
            <!-- ETAPE 0 : DASHBOARD -->
            <!-- ============================================ -->
            <Grid x:Name="Step0Panel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Stats Cards -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3498db" Offset="0"/>
                                <GradientStop Color="#2980b9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="HDD" FontSize="24" FontWeight="Bold" Foreground="#ffffff" Opacity="0.7" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtStatDisks" Text="0" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="DISQUES EFFACES" FontSize="11" Foreground="White" Opacity="0.9" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="10" Padding="20" Margin="5,0,5,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#9b59b6" Offset="0"/>
                                <GradientStop Color="#8e44ad" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="CLI" FontSize="24" FontWeight="Bold" Foreground="#ffffff" Opacity="0.7" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtStatClients" Text="0" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="CLIENTS TRAITES" FontSize="11" Foreground="White" Opacity="0.9" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="10" Padding="20" Margin="5,0,5,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#e67e22" Offset="0"/>
                                <GradientStop Color="#d35400" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="SES" FontSize="24" FontWeight="Bold" Foreground="#ffffff" Opacity="0.7" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtStatSessions" Text="0" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="SESSIONS" FontSize="11" Foreground="White" Opacity="0.9" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#27ae60" Offset="0"/>
                                <GradientStop Color="#229954" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="OK" FontSize="24" FontWeight="Bold" Foreground="#ffffff" Opacity="0.7" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtStatSuccess" Text="100%" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="TAUX DE SUCCES" FontSize="11" Foreground="White" Opacity="0.9" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Activite recente -->
                <Border Grid.Row="1" Background="#f8f9fa" CornerRadius="10" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Activite recente (7 derniers jours) - Double-clic pour voir les details" FontSize="16" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <DataGrid x:Name="DgRecentActivity"
                                 Grid.Row="1"
                                 AutoGenerateColumns="False"
                                 CanUserAddRows="False"
                                 CanUserDeleteRows="False"
                                 IsReadOnly="True"
                                 HeadersVisibility="Column"
                                 GridLinesVisibility="Horizontal"
                                 AlternatingRowBackground="#ffffff"
                                 Background="#f8f9fa"
                                 BorderThickness="0"
                                 RowBackground="#f8f9fa">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding DateStr}" Width="150"/>
                                <DataGridTextColumn Header="Client" Binding="{Binding Customer}" Width="200"/>
                                <DataGridTextColumn Header="Technicien" Binding="{Binding Technicien}" Width="150"/>
                                <DataGridTextColumn Header="Disques" Binding="{Binding DiskCount}" Width="80"/>
                                <DataGridTextColumn Header="Site" Binding="{Binding Site}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 1 : SELECTION DES DISQUES -->
            <!-- ============================================ -->
            <Grid x:Name="Step1Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Cochez les disques a effacer :" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid x:Name="DgDisks"
                         Grid.Row="1"
                         AutoGenerateColumns="False"
                         CanUserAddRows="False"
                         CanUserDeleteRows="False"
                         SelectionMode="Single"
                         SelectionUnit="FullRow"
                         HeadersVisibility="Column"
                         GridLinesVisibility="Horizontal"
                         AlternatingRowBackground="#f8f9fa"
                         IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Selectionner" Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        <DataGridTextColumn Header="No" Binding="{Binding Number}" Width="40" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Modele" Binding="{Binding Model}" Width="200" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Taille" Binding="{Binding SizeGB}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Utilise (Go)" Binding="{Binding UsedGB}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Lettre" Binding="{Binding DriveLetter}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Bus" Binding="{Binding Bus}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="BitLocker" Binding="{Binding BitLockerStatus}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Etat" Binding="{Binding Status}" Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="BtnSelectAll" Content="Tout selectionner" Width="130" Height="30" Margin="0,0,10,0"/>
                    <Button x:Name="BtnDeselectAll" Content="Tout deselectionner" Width="130" Height="30"/>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 2 : INFORMATIONS CLIENT -->
            <!-- ============================================ -->
            <Grid x:Name="Step2Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                    <TextBlock Text="Societe / Client *" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbSociete"
                             Height="35"
                             Margin="0,0,0,20"
                             FontSize="14"
                             IsEditable="True"
                             IsTextSearchEnabled="True"
                             StaysOpenOnEdit="True"/>

                    <TextBlock Text="Site" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtSite" Height="30" Margin="0,0,0,20" FontSize="14"/>

                    <TextBlock Text="Ville" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtVille" Height="30" Margin="0,0,0,20" FontSize="14"/>

                    <TextBlock Text="Technicien *" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbTechnicien"
                             Height="35"
                             FontSize="14"
                             IsEditable="True"
                             IsTextSearchEnabled="True"
                             StaysOpenOnEdit="True"/>
                    <TextBlock Text="* Champs obligatoires" FontSize="11" Foreground="Gray" Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 3 : OPTIONS D'EFFACEMENT -->
            <!-- ============================================ -->
            <Grid x:Name="Step3Panel" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">

                    <TextBlock Text="Mode d'effacement" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <RadioButton x:Name="RbFast" Content="Fast (effacement rapide)" GroupName="WipeMode"
                                IsChecked="True" Margin="0,5,0,5" FontSize="14"/>
                    <TextBlock Text="Effacement rapide (recommande pour la plupart des cas)"
                              Foreground="Gray" FontSize="11" Margin="25,0,0,15"/>

                    <RadioButton x:Name="RbSecure" Content="Secure (effacement securise complet)" GroupName="WipeMode"
                                Margin="0,5,0,5" FontSize="14"/>
                    <TextBlock Text="Effacement complet (plus long, reecrit tous les secteurs)"
                              Foreground="Gray" FontSize="11" Margin="25,0,0,25"/>

                    <Separator Margin="0,10,0,20"/>

                    <CheckBox x:Name="ChkBitLocker" Content="Pre-chiffrer avec BitLocker avant effacement"
                             Margin="0,0,0,5" FontSize="14"/>
                    <TextBlock Text="(Option experimentale - augmente considerablement le temps de traitement)"
                              Foreground="Gray" FontSize="11" Margin="25,0,0,25"/>

                    <Separator Margin="0,10,0,20"/>

                    <CheckBox x:Name="ChkCreatePartition" Content="Creer une partition apres effacement"
                             IsChecked="True" Margin="0,0,0,5" FontSize="14"/>
                    <TextBlock Text="Si coche, une partition NTFS sera creee apres l'effacement"
                              Foreground="Gray" FontSize="11" Margin="25,0,0,15"/>

                    <TextBlock Text="Etiquette du volume apres formatage" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtVolumeLabel" Text="" Height="30" FontSize="14"/>
                    <TextBlock Text="Laissez vide pour ne pas attribuer d'etiquette, ou saisissez un nom (ex: Data)"
                              Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 3.5 : RESUME AVANT EXECUTION -->
            <!-- ============================================ -->
            <Grid x:Name="StepSummaryPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Verification avant effacement" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Section Client -->
                        <Border Background="#e8f4f8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Informations client" FontWeight="Bold" FontSize="14" Foreground="#2980b9" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Societe :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtSummarySociete" Text="-"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Site :" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtSummarySite" Text="-" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ville :" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtSummaryVille" Text="-" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Technicien :" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtSummaryTechnicien" Text="-" Margin="0,5,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Section Options -->
                        <Border Background="#fef9e7" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Options d'effacement" FontWeight="Bold" FontSize="14" Foreground="#d68910" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode :" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtSummaryMode" Text="-"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="BitLocker :" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtSummaryBitLocker" Text="-" Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Etiquette :" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtSummaryLabel" Text="-" Margin="0,5,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Section Disques -->
                        <Border Background="#fdedec" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock x:Name="TxtSummaryDiskCount" Text="Disques a effacer (0)" FontWeight="Bold" FontSize="14" Foreground="#c0392b" Margin="0,0,0,10"/>
                                <DataGrid x:Name="DgSummaryDisks"
                                         AutoGenerateColumns="False"
                                         CanUserAddRows="False"
                                         CanUserDeleteRows="False"
                                         IsReadOnly="True"
                                         HeadersVisibility="Column"
                                         GridLinesVisibility="Horizontal"
                                         MaxHeight="200"
                                         Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="No" Binding="{Binding Number}" Width="50"/>
                                        <DataGridTextColumn Header="Modele" Binding="{Binding Model}" Width="250"/>
                                        <DataGridTextColumn Header="Taille" Binding="{Binding SizeGB}" Width="100"/>
                                        <DataGridTextColumn Header="Bus" Binding="{Binding Bus}" Width="100"/>
                                        <DataGridTextColumn Header="Lettre" Binding="{Binding DriveLetter}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#e74c3c" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                    <TextBlock Text="ATTENTION : L'effacement des disques est definitif et irreversible. Verifiez attentivement les informations ci-dessus avant de continuer."
                              Foreground="White" TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 4 : EXECUTION -->
            <!-- ============================================ -->
            <Grid x:Name="Step4Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="TxtProgressInfo"
                              Text="Effacement en cours..."
                              FontSize="14"
                              FontWeight="Bold"
                              Margin="0,0,0,10"/>
                    <ProgressBar x:Name="PbProgress"
                                Height="30"
                                Minimum="0"
                                Maximum="100"
                                Value="0"
                                Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtCurrentDisk"
                              Text=""
                              FontSize="12"
                              Foreground="Gray"
                              Margin="0,0,0,10"/>
                </StackPanel>

                <Separator Grid.Row="1" Margin="0,10,0,10"/>

                <Border Grid.Row="2" BorderBrush="#dfe6e9" BorderThickness="1" CornerRadius="3">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="TxtLogs"
                                TextWrapping="Wrap"
                                IsReadOnly="True"
                                Background="#f8f9fa"
                                BorderThickness="0"
                                FontFamily="Consolas"
                                FontSize="11"
                                Padding="10"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 5 : POST-ACTIONS -->
            <!-- ============================================ -->
            <Grid x:Name="Step5Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                          Text="Effacement termine ! Choisissez les actions finales :"
                          FontSize="14"
                          FontWeight="Bold"
                          Margin="0,0,0,15"/>

                <DataGrid x:Name="DgPostActions"
                         Grid.Row="1"
                         AutoGenerateColumns="False"
                         CanUserAddRows="False"
                         CanUserDeleteRows="False"
                         IsReadOnly="True"
                         HeadersVisibility="Column"
                         GridLinesVisibility="Horizontal"
                         AlternatingRowBackground="#f8f9fa">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="No" Binding="{Binding Number}" Width="40"/>
                        <DataGridTextColumn Header="Modele" Binding="{Binding Model}" Width="200"/>
                        <DataGridTextColumn Header="S/N" Binding="{Binding Serial}" Width="150"/>
                        <DataGridTextColumn Header="Taille" Binding="{Binding SizeGB}" Width="80"/>
                        <DataGridTextColumn Header="Duree" Binding="{Binding Duration}" Width="80"/>
                        <DataGridTextColumn Header="Resultat" Binding="{Binding Result}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="BtnAssignLetters"
                           Content="Assigner lettres de lecteur"
                           Width="200"
                           Height="40"
                           FontSize="14"
                           Margin="0,0,15,0"
                           Background="#3498db"
                           Foreground="White"/>
                    <Button x:Name="BtnEjectAll"
                           Content="Ejecter tous les disques"
                           Width="200"
                           Height="40"
                           FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- ETAPE 6 : FINALISATION -->
            <!-- ============================================ -->
            <Grid x:Name="Step6Panel" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="600">
                    <TextBlock Text="Operation terminee avec succes !"
                              FontSize="24"
                              FontWeight="Bold"
                              Foreground="#27ae60"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20"/>

                    <!-- Infos fichiers generes -->
                    <Border Background="#f8f9fa" BorderBrush="#dfe6e9" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Fichiers generes :" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                <TextBlock Text="Certificat client :" Width="120" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtCertificatePath" Text="-" TextWrapping="Wrap" Width="400"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                <TextBlock Text="Rapport session :" Width="120" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtRapportPath" Text="-" TextWrapping="Wrap" Width="400"/>
                            </StackPanel>

                            <Button x:Name="BtnOpenLogsFolder"
                                   Content="Ouvrir le dossier des logs"
                                   Width="180"
                                   Height="30"
                                   Margin="0,15,0,0"
                                   HorizontalAlignment="Left"
                                   FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Que souhaitez-vous faire ?"
                              FontSize="16"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnRestartSameClient"
                               Content="Recommencer pour ce client"
                               Width="220"
                               Height="50"
                               FontSize="14"
                               Margin="0,0,20,0"/>
                        <Button x:Name="BtnFinish"
                               Content="Terminer"
                               Width="150"
                               Height="50"
                               FontSize="14"
                               Background="#27ae60"
                               Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            </Grid>
        </Border>

        <!-- Barre de navigation -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnPrevious"
                       Grid.Column="0"
                       Content="Precedent"
                       Width="130"
                       Height="38"
                       HorizontalAlignment="Left"
                       FontSize="13"
                       IsEnabled="False"
                       Background="#95a5a6"
                       Foreground="White"
                       FontWeight="SemiBold"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnNext"
                           Content="Commencer"
                           Width="150"
                           Height="38"
                           Margin="0,0,10,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#667eea" Offset="0"/>
                                <GradientStop Color="#764ba2" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button x:Name="BtnCancel"
                           Content="Annuler"
                           Width="110"
                           Height="38"
                           FontSize="13"
                           Background="#e74c3c"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
